      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "SignalR Connections",
      "type": "timeseries",
      "targets": [
        {
          "expr": "chat_signalr_connections"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Message Events / sec",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(message_events_total[1m])"
        }
      ],
